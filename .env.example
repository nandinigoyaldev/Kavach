SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Optional AI chat fallback (cloud)
OPENAI_API_KEY=
AI_CHAT_API_KEY=
AI_CHAT_API_BASE=https://api.openai.com/v1
AI_CHAT_MODEL=gpt-4o-mini

# Optional local AI chat (Ollama)
AI_LOCAL_API_BASE=http://127.0.0.1:11434
AI_LOCAL_MODEL=llama3.2:3b
AI_AUTO_START_OLLAMA=true

# Optional camera selection, example: 0 or 0,1
CAMERA_INDEX=

# Visual and render tuning
JARVIS_THEME=auto
RENDER_QUALITY=balanced
SHOW_FPS=true
JARVIS_BUILD_TAG=v1.0.0

# Optional Google Tasks voice CRUD
GOOGLE_TASKS_CLIENT_ID=
GOOGLE_TASKS_CLIENT_SECRET=
GOOGLE_TASKS_REFRESH_TOKEN=
GOOGLE_TASKS_ACCESS_TOKEN=
GOOGLE_TASK_LIST_ID=
GOOGLE_TASK_LIST_NAME=
